{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pcb",
  "version": "0.0.0",
  "identifier": "dev.kidandcat.pcb",
  "build": {
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "pcb",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
